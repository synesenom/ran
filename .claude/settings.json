{
  "permissions": {
    "allow": [
      "Edit(.claude/tmp*)",
      "Write(.claude/tmp*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(mkdir*/.claude/tmp*)",
      "Bash(mkdir .claude/tmp*)"
    ]
  },
  "enabledMcpjsonServers": ["codescene"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
