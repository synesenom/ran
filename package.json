{
  "name": "ranjs",
  "version": "1.24.6",
  "description": "Library for generating various random variables.",
  "keywords": [
    "random",
    "generator",
    "distributions",
    "mcmc",
    "statistics",
    "test"
  ],
  "homepage": "https://synesenom.github.io/ran/",
  "author": {
    "name": "Enys Mones",
    "url": "enysmones.com",
    "email": "enys.mones@gmail.com"
  },
  "license": "MIT",
  "main": "./dist/ranjs.min.js",
  "module": "./dist/ranjs.esm.js",
  "exports": {
    ".": {
      "import": "./dist/ranjs.esm.js",
      "require": "./dist/ranjs.cjs.js",
      "default": "./dist/ranjs.min.js"
    }
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/synesenom/ran"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "scripts": {
    "lint": "./node_modules/.bin/standard src/**/*.js test/*.js",
    "standard": "./node_modules/.bin/standard --fix src/**/*.js test/*.js",
    "test": "./node_modules/.bin/_mocha --require @babel/register",
    "docs": "node ./docs/index.js",
    "build": "./node_modules/.bin/rollup -c",
    "prepublishOnly": "npm run build",
    "coverage": "cross-env NODE_ENV=test nyc --reporter=html _mocha --require @babel/register"
  },
  "devDependencies": {
    "@babel/core": "^7.18.6",
    "@babel/polyfill": "^7.12.1",
    "@babel/preset-env": "^7.15.6",
    "@babel/register": "^7.15.3",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "babel-plugin-istanbul": "^6.0.0",
    "badge-maker": "^5.0.2",
    "chai": "^4.3.4",
    "cross-env": "^7.0.3",
    "documentation": "^14.0.0",
    "eslint": "^7.32.0",
    "eslint-config-standard": "^16.0.3",
    "highlight.js": "^11.7.0",
    "istanbul": "^0.4.5",
    "lodash.flattendeep": "^4.4.0",
    "mathjax-node-page": "^3.2.0",
    "mocha": "^10.2.0",
    "nodemon": "^3.0.0",
    "nyc": "^15.1.0",
    "pug": "^3.0.2",
    "rollup": "^4.60.4",
    "sass": "^1.77.8",
    "seedrandom": "^3.0.5",
    "standard": "^16.0.4"
  },
  "babel": {
    "presets": [
      "@babel/preset-env"
    ],
    "env": {
      "test": {
        "plugins": [
          "istanbul"
        ]
      }
    }
  },
  "nyc": {
    "exclude": [
      "test"
    ],
    "include": [
      "src/**/*.js"
    ],
    "sourceMap": false,
    "instrument": false,
    "require": [
      "@babel/register"
    ]
  }
}
